# OPTIONAL — only needed for the AI showcase step (scripts/generate_showcase.py).
# Copy this file to .env and fill in your key. The core skill needs none of this.
#   cp .env.example .env

# Your Gemini / Nano Banana API key (required for the showcase step).
GEMINI_API_KEY=your_api_key_here

# Optional: a third-party / proxy endpoint. Leave blank to use the official Google API.
GEMINI_API_BASE_URL=

# Optional: override the image model.
GEMINI_MODEL=gemini-3.1-flash-image-preview
